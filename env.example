# ── Olly's Card Scanner — Environment Variables ──────────────────────────

# Your Anthropic API key (get it from https://console.anthropic.com)
ANTHROPIC_API_KEY=sk-ant-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# Your deployed Google Apps Script Web App URL
# (See README for how to get this)
GOOGLE_APPS_SCRIPT_URL=https://script.google.com/macros/s/YOUR_SCRIPT_ID/exec

# Optional: restrict CORS to your frontend URL
# Leave blank to allow all origins during development
FRONTEND_URL=

# Port (Render sets this automatically)
PORT=3001
